# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# If using Terraform (recommended), this is injected automatically – run:
#   terraform -chdir=terraform output -raw env_file_contents > .env
#
# If setting up manually, provide your Atlas connection string:
#   mongodb+srv://<user>:<password>@<cluster>.<host>.mongodb.net
# Or for a local Atlas deployment:
#   mongodb://localhost:27017/?directConnection=true
MONGODB_URI=<auto-injected by terraform, or set manually>

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
