{
  "name": "mongodb-agentic-ai-bots",
  "version": "1.0.0",
  "description": "Multi-agent AI system with MongoDB Atlas, LangGraph.js, and Voyage AI",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node --project tsconfig.ts-node.json index.ts",
    "dev": "ts-node --project tsconfig.ts-node.json --watch index.ts",
    "seed": "ts-node --project tsconfig.ts-node.json seed-database.ts",
    "mcp-server": "ts-node --project tsconfig.ts-node.json mcp-server/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@langchain/community": "^1.1.0",
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint-mongodb": "^1.3.0",
    "@langchain/mongodb": "^1.2.0",
    "@langchain/openai": "^1.4.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.15.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.18",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
